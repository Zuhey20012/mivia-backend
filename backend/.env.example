# Malvoya Backend — Environment Variables
# Copy this file to .env and fill in your real values

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mivia?schema=public"
REDIS_URL="redis://127.0.0.1:6379"
PORT=4000
NODE_ENV=development
JWT_SECRET="CHANGE_ME_TO_A_STRONG_64_CHAR_SECRET"
JWT_REFRESH_SECRET="CHANGE_ME_TO_A_DIFFERENT_STRONG_64_CHAR_SECRET"
LOG_LEVEL=info
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_KEY_HERE"
CLOUDINARY_URL="cloudinary://YOUR_CLOUDINARY_URL_HERE"
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID_HERE"
ALLOWED_ORIGINS="*"
